{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "STM32F103C8T6 Build + Flash + Debug",
            "type": "cortex-debug",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "servertype": "stlink",
            "stlinkPath": "D:/ST/STM32CubeCLT_1.21.0/STLink-gdb-server/bin/ST-LINK_gdbserver.exe",
            "armToolchainPath": "D:/ST/STM32CubeCLT_1.21.0/GNU-tools-for-STM32/bin",
            "gdbPath": "D:/ST/STM32CubeCLT_1.21.0/GNU-tools-for-STM32/bin/arm-none-eabi-gdb.exe",
            "device": "STM32F103C8Tx",
            "interface": "swd",
            "runToEntryPoint": "main",
            "showDevDebugOutput": "raw",
            "executable": "${workspaceFolder}/build/Debug/STM32_ESC_DSHOT_H1.elf",
            "preLaunchTask": "STM32: Build + Flash",
            "postRestartCommands": [
                "monitor reset"
            ]
        }
    ]
}
